{
  "manifest_version": 3,
  "name": "Arc Tunnel",
  "version": "1.0.0",
  "description": "AI-powered browser automation",
  "permissions": [
    "debugger",
    "tabs",
    "storage",
    "cookies",
    "scripting",
    "unlimitedStorage",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
